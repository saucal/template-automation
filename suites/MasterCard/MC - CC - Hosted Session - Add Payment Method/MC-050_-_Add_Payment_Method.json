      "sequence": 0,
      "target": "",
      "value": "return new Promise(function (resolve, reject) {\n  const username = \"{{adminUser}}\"; \n  const password = \"{{wp_api_pass}}\"; \n  const url = \"{{startUrl}}wp-json/custom/v1/to_checkout_classic\";\n  let headers = new Headers();\n  headers.set('Content-Type', 'application/json');\n  headers.set('Authorization', 'Basic ' + btoa(username + \":\" + password));\n  fetch(url, {method:'GET',\n      headers: headers\n      })\n  .then(function(response) {\n    if (response.ok) {\n    resolve(response.json())\n    } else {\n    reject(new Error('error'))\n    } \n  })\n})",
      "variableName": ""
    },
    {
      "command": "eval",
      "condition": null,
      "optional": false,
      "private": false,
      "sequence": 1,
      "target": "",
      "value": "return new Promise(function (resolve, reject) {\n  const key = '{{key}}';\n  const newValue = '{{newValue}}'\n  const data = JSON.stringify({\n            option_name: 'woocommerce_mastercard_merchant_cloud_settings',// Replace with your option name\n            updates: {\n                \"_3d_secure\": 'yes', \n                \"saved_cards\": 'yes',\n                \"transaction_mode\": 'PURCHASE',\n                \"checkout_mode\": 'hosted_session'\n            }\n        })\n  const username = \"{{adminUser}}\"; \n  const password = \"{{wp_api_pass}}\"; \n  const url = \"{{startUrl}}wp-json/custom/v1/update-option\";\n  let headers = new Headers();\n  headers.set('Content-Type', 'application/json');\n  headers.set('Authorization', 'Basic ' + btoa(username + \":\" + password));\n  fetch(url, {method:'POST',\n      body: data,\n      headers: headers\n      })\n  .then(function(response) {\n    if (response.ok) {\n    resolve(response.json())\n    } else {\n    reject(new Error('error'))\n    } \n  })\n})",
      "variableName": ""
    },
