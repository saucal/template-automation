      "sequence": 0,
      "target": "",
      "value": "return new Promise(function (resolve, reject) {\n  const order = {{orderNumber}};\n  const username = \"{{woo_user}}\"; \n  const password = \"{{woo_pass}}\"; \n  const url = \"{{url}}/wp-json/wc/v3/orders/\"+order;\n  let headers = new Headers();\n  headers.set('Content-Type', 'application/json');\n  headers.set('Authorization', 'Basic ' + btoa(username + \":\" + password));\n  fetch(url, {method:'GET',\n      headers: headers,\n      })\n  .then(function(response) {\n    if (response.ok) {\n    resolve(response.json())\n    } else {\n    reject(new Error('error'))\n    } \n  })\n})",
      "variableName": "myOrder"
    },
    {
      "command": "extractEval",
      "condition": null,
      "optional": false,
      "private": false,
      "sequence": 1,
      "target": "",
      "value": "const jsonOrder = {{myOrder}}\nreturn jsonOrder.transaction_id",
      "variableName": "transaction_id"
    },
