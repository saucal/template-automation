      "value": "const price = parseFloat(\"{{unitPrice}}\".replace(\"{{Symbol}}\",\"\").replaceAll(\",\",\"\").trim());\nconst subProdPrice = parseFloat(\"{{subProdPrice}}\".replace(\"{{Symbol}}\",\"\").replaceAll(\",\",\"\").trim());\nconst signUpFee = parseFloat(\"{{signUpFee}}\".replace(\"{{Symbol}}\",\"\").replaceAll(\",\",\"\").trim());\nconst subtotal = parseFloat(\"{{subtotal}}\".replace(\"{{Symbol}}\",\"\").replaceAll(\",\",\"\").trim());\nconst total = parseFloat(\"{{total}}\".replace(\"{{Symbol}}\",\"\").replaceAll(\",\",\"\").trim());\nconst recurringSubtotal = parseFloat(\"{{recurringSubtotal}}\".replace(\"{{Symbol}}\",\"\").replaceAll(\",\",\"\").trim());\nconst recurringTotal = parseFloat(\"{{recurringTotal}}\".replace(\"{{Symbol}}\",\"\").replaceAll(\",\",\"\").trim());\n\nconst qty = {{qty}};\nlet subProdPrice2 = price * qty\nlet subtotal2 = subProdPrice2 + ( signUpFee * 2 )\nlet total2 = subtotal2\n\nreturn subProdPrice === subProdPrice2 \n        && subtotal2 === subtotal \n        && total2 === total\n        && subProdPrice2 === recurringSubtotal\n        && subProdPrice2 === recurringTotal",
