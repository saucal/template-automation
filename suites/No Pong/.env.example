# Region base URLs. TRAILING SLASH REQUIRED for CA/US subsite path resolution
# (rule 12 — goto is always relative, never a leading slash).
# Per-region, per-tier base URLs. Region → --project (au|ca|us); tier → TARGET_ENV.
# Select the tier at run time (default preprod):  TARGET_ENV=develop npx playwright test --project=au
TARGET_ENV=preprod
BASE_URL_AU_PREPROD=https://nopong-au.example/
BASE_URL_CA_PREPROD=https://nopong-americas.example/ca/
BASE_URL_US_PREPROD=https://nopong-americas.example/us/
BASE_URL_AU_DEVELOP=https://nopong-au-develop.example/
BASE_URL_CA_DEVELOP=https://nopong-americas-develop.example/ca/
BASE_URL_US_DEVELOP=https://nopong-americas-develop.example/us/

# WordPress admin credentials — used for browser session (global-setup, per host).
# Admin user must exist on EACH CA/US subsite (rule 12).
WP_ADMIN_USER=saucal_maintenance_admin
ADMIN_PASS=

# Stripe test card is hardcoded (4242…). PayPal sandbox account:
PAY_PAL_USER=
PAY_PAL_PASS=

# Pre-provisioned wholesale customer account (NP-AU-WS spec). Spec skips if unset.
WHOLESALE_USER=
WHOLESALE_PASS=

# Private GI test variables (account passwords used by set-password / login flows).
PASSWORD=
PASSWORD2=

# Stagehand AI fallback (rule 23). Leave unset to run pure Playwright tiers.
ANTHROPIC_API_KEY=
STAGEHAND_MODEL=anthropic/claude-sonnet-4-6

# Optional — override the Playgrounds Mailpit inbox host.
MAILPIT_URL=

# Gate refund/destructive specs to ONE region (rule 12).
REFUND_PROJECT=au
