      "target": "",
      "value": "function checkAdminNote(note) {\n    const pattern = /Stripe charge complete \\(Charge ID: ch_[a-zA-Z0-9]+\\)/;\n    return pattern.test(note);\n}\n\n// Select all <p> elements within ul.order_notes > li > div > p\nconst notes = document.querySelectorAll('ul.order_notes > li > div > p');\n\n// Check if any note matches the pattern\nreturn Array.from(notes).some(note => checkAdminNote(note.textContent));\n",
      "variableName": ""
    },
    {
      "command": "assertEval",
      "condition": null,
      "optional": false,
      "private": false,
      "sequence": 28,
      "target": "",
      "value": "function checkAdminNote(note) {\n    const pattern = /Customer has earned {{earnPoints}} points. New balance is {{balance}} points./;\n    return pattern.test(note);\n}\n\n// Select all <p> elements within ul.order_notes > li > div > p\nconst notes = document.querySelectorAll('ul.order_notes > li > div > p');\n\n// Check if any note matches the pattern\nreturn Array.from(notes).some(note => checkAdminNote(note.textContent));\n",
      "variableName": ""
    },
