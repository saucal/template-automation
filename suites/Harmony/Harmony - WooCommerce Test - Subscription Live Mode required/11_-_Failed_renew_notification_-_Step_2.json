      "value": "let count = document.querySelectorAll('div#renewal_payment_retries table > tbody > tr').length\nreturn count === 5",
      "variableName": ""
    },
    {
      "command": "assertEval",
      "condition": null,
      "optional": false,
      "private": false,
      "sequence": 46,
      "target": "",
      "value": "let notes = document.querySelectorAll('li > div.note_content > p')\nlet count = notes.length\nlet i = 0;\nlet boolean = true\nwhile (i < count && boolean === true) {\n    boolean = notes[i].textContent.includes( 'Order status changed from Pending payment to Failed.' )\n    if (boolean === true) {\n        i = i + 3\n    }\n}\n\ni = 1\n\nwhile (i < count && boolean === true) {\n    boolean = notes[i].textContent.includes('The card was declined.')\n    if (boolean === true) {\n        i = i + 3\n    }\n}\n\ni = 2\n\nwhile (i < count && boolean === true) {\n    boolean = notes[i].textContent === 'Retry rule applied: Order status changed from Failed to Pending payment.'\n    if (boolean === true) {\n        i = i + 3\n    }\n}\n\nreturn boolean\n\n",
