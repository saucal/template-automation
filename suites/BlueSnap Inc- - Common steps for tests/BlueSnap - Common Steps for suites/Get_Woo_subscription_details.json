  "steps": [
    {
      "command": "extractEval",
      "condition": null,
      "optional": false,
      "private": false,
      "sequence": 0,
      "target": "",
      "value": "return new Promise(function (resolve, reject) {\n  const subscription = {{subscriptionID}};\n  const username = \"{{woo_user}}\"; \n  const password = \"{{woo_pass}}\"; \n  const url = \"{{startUrl}}wp-json/wc/v3/subscriptions/\"+subscription;\n  let headers = new Headers();\n  headers.set('Content-Type', 'application/json');\n  headers.set('Authorization', 'Basic ' + btoa(username + \":\" + password));\n  fetch(url, {method:'GET',\n      headers: headers, \n      credentials: 'omit'\n      })\n  .then(function(response) {\n    if (response.ok) {\n    resolve(response.json())\n    } else {\n    reject(new Error('error'))\n    } \n  })\n})",
      "variableName": "mySubscription"
    },
    {
      "command": "extractEval",
      "condition": null,
      "optional": false,
      "private": false,
      "sequence": 1,
      "target": "",
      "value": "const jsonOrder = {{mySubscription}}\nreturn Number(jsonOrder.total)",
      "variableName": "totalRenew"
    },
    {
      "command": "assertEval",
      "condition": {
        "statement": "let id = \"{{testID}}\"\nreturn id != \"BLU-002-029\" && id != \"BLU-002-031\""
      },
      "optional": false,
      "private": false,
      "sequence": 2,
      "target": "",
      "value": "const jsonOrder = {{mySubscription}}\nreturn jsonOrder.payment_method_title === \"{{paymentMethodTitle}}\"",
      "variableName": ""
    },
    {
      "command": "extractEval",
      "condition": {
        "statement": "let id = \"{{testID}}\" \nreturn id === \"BLU-002-029\" ||  id === \"BLU-002-031\""
      },
      "optional": false,
      "private": false,
      "sequence": 3,
      "target": "",
      "value": "const jsonOrder = {{mySubscription}}\nreturn jsonOrder.payment_method_title",
      "variableName": "paymentMethodTitle"
    },
