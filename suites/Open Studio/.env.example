# Base URL of the staging site (no trailing slash)
BASE_URL=https://openstudio-staging.mystagingwebsite.com

# WordPress admin credentials — used for browser session (global-setup)
WP_ADMIN_USER=
ADMIN_PASS=

# OPTIONAL — reuse an EXISTING Open Studio member (one that already purchased a
# membership). If set, member.setup logs this account in and saves its session for
# the member specs. If UNSET, member.setup creates a fresh member via the join flow
# (one real Stripe membership purchase per run). No fake default — the member specs
# always run against a genuine purchaser.
MEMBER_EMAIL=
MEMBER_PASS=

# Stagehand AI fallback (resilient locators). Leave unset for pure Playwright tiers.
ANTHROPIC_API_KEY=
STAGEHAND_MODEL=anthropic/claude-sonnet-4-6

# Optional — override the Playgrounds Mailpit inbox host (if email source = plugin).
MAILPIT_URL=

# Destructive-spec gates (real side effects on staging). Set to any value to run.
RUN_REFUND=true
RUN_RENEW=true
