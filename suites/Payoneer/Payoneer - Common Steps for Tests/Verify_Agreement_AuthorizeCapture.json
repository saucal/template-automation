      "target": "",
      "value": "const log = {{log}}\n\nreturn log.request.body.agreement.id === 'acme_subscription-order-{{subscriptionID}}' &&\n    log.response.body.agreement.id === 'acme_subscription-order-{{subscriptionID}}'",
      "variableName": ""
