      "optional": false,
      "private": false,
      "sequence": 3,
      "target": "",
      "value": "const log = {{log}}\n\nreturn log.request.body.agreement.paymentFrequency === '{{freq}}' &&\n    log.response.body.agreement.paymentFrequency === '{{freq}}'",
      "variableName": ""
    },
    {
      "command": "assertEval",
      "condition": {
        "statement": "const renewal = '{{renewal}}'\n\nreturn renewal !== 'yes'"
      },
      "optional": false,
      "private": false,
      "sequence": 4,
      "target": "",
      "value": "const log = {{log}}\nconst dateString = \"{{payDate}}\";\nconst date = new Date(dateString);\nconst formattedDate = date.toISOString().split('T')[0];\n\nreturn log.request.body.agreement.startDate === formattedDate &&\n    log.response.body.agreement.startDate === formattedDate",
      "variableName": ""
    },
    {
      "command": "assertEval",
      "condition": {
        "statement": "const renewal = '{{renewal}}'\n\nreturn renewal !== 'yes'"
      },
      "optional": false,
      "private": false,
      "sequence": 5,
      "target": "",
      "value": "const log = {{log}}\nconst dateString = \"{{payDate}}\";\nconst frequency = \"{{freq}}\";\nlet formattedDate;\n\nif (frequency === \"MONTHLY\") {\n  const date = new Date(dateString);\n  date.setMonth(date.getMonth() + 1); // Add one month\n  formattedDate = date.toISOString().split('T')[0]; // Extract YYYY-MM-DD\n  console.log(formattedDate); // Output: \"2025-11-17\"\n}\n\nreturn log.request.body.agreement.expiryDate === formattedDate &&\n    log.response.body.agreement.expiryDate === formattedDate",
      "variableName": ""
    },
    {
      "command": "assertEval",
      "condition": {
        "statement": "const renewal = '{{renewal}}'\n\nreturn renewal !== 'yes'"
      },
      "optional": false,
      "private": false,
      "sequence": 6,
      "target": "",
      "value": "const log = {{log}}\nconst dateString = \"{{payDate}}\";\nconst frequency = \"{{freq}}\";\nlet daysInMonth;\n\nif (frequency === \"MONTHLY\") {\n  const date = new Date(dateString);\n  const year = date.getFullYear();\n  const month = date.getMonth(); // 0-based month (November is 10)\n  daysInMonth = parseInt(new Date(year, month + 1, 0).getDate());\n}\n\nreturn log.request.body.agreement.minimumDaysBetweenPayments === daysInMonth &&\n    log.response.body.agreement.minimumDaysBetweenPayments === daysInMonth",
      "variableName": ""
    }
