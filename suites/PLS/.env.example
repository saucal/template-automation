# PLS staging site under test (single host — trailing slash required, all goto()
# calls are relative).
BASE_URL=https://pls-maintenance.mystagingwebsite.com/

# WordPress admin credentials (browser session; lazy login on first adminPage use
# → auth/admin-<project>.json).
WP_ADMIN_USER=saucal_maintenance_admin
ADMIN_PASS=

# Existing staging customer for the login / My Account spec.
STAGING_USER_EMAIL=qa+gi_staging_user@saucal.com
# Its password (login is attempted with PASSWORD, then PASSWORD2 — matches the GI
# convention where the forgot-password flow leaves the account on PASSWORD2).
PASSWORD=
PASSWORD2=

# Stagehand AI locator fallback (rule 23). Leave unset to run pure Playwright tiers.
ANTHROPIC_API_KEY=
STAGEHAND_MODEL=anthropic/claude-sonnet-4-6

# Optional — override the Playgrounds Mailpit inbox host.
MAILPIT_URL=
