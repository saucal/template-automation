{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "typeRoots": ["node_modules/@types"]
  },
  "include": [
    "playwright.config.ts",
    "admin-login.ts",
    "types/**/*.ts",
    "fixtures/**/*.ts",
    "helpers/**/*.ts",
    "specs/**/*.ts"
  ],
  "exclude": ["node_modules", "generated"]
}
