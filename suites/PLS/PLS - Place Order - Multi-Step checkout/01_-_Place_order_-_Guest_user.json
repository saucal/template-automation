    {
      "command": "assertEval",
      "condition": null,
      "optional": false,
      "private": false,
      "sequence": 34,
      "target": "",
      "value": "function checkCredentialsPresence() {\n  const expected = [\n    'Admin', 'CDA', 'CRDH', 'DA', 'DDS', 'DH', 'DMD', \n    'FTD', 'O.Mgr', 'RDA', 'RDH', 'Recptn', 'RN', 'Other'\n  ];\n\n  const selects = document.querySelectorAll('.pls-field-credentials');\n\n  if (selects.length !== 3) {\n    console.error(`Expected 3 selects → found only ${selects.length}`);\n    return false;\n  }\n\n  let allGood = true;\n\n  selects.forEach((select, index) => {\n    const present = new Set(\n      [...select.querySelectorAll('option:not(:disabled)')]\n        .map(opt => opt.textContent.trim())\n        .filter(t => t.length > 0)\n    );\n\n    const missing = expected.filter(item => !present.has(item));\n\n    if (missing.length > 0) {\n      allGood = false;\n      console.warn(\n        `%cDropdown #${index + 1} is missing:${missing.length} items`,\n        'color: #e74c3c; font-weight: bold;'\n      );\n      console.log('   Missing →', missing.join(', '));\n\n      // Optional: show what IS present (helps spot typos/case issues)\n      console.log('   Present →', [...present].sort().join(', '));\n      console.log(''); // empty line for readability\n    } else {\n      console.log(\n        `%cDropdown #${index + 1} → all ${expected.length} items present ✓`,\n        'color: #2ecc71;'\n      );\n    }\n  });\n\n  if (allGood) {\n    console.log(\n      '%cALL THREE DROPDOWNS LOOK CORRECT 🎉',\n      'color: #2ecc71; font-weight: bold; font-size: 1.1em;'\n    );\n  } else {\n    console.error('One or more dropdowns are missing credentials');\n  }\n\n  return allGood;\n}\n\n// Run it\nreturn checkCredentialsPresence();",
      "variableName": ""
    },
