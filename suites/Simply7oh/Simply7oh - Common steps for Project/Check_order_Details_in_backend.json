      "sequence": 14,
      "target": "",
      "value": "function checkAdminNote(note) {\n    const total = '{{total}}'.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&')\n    const pattern = new RegExp(`Authorize\\\\.net charge completed for ${total} \\\\(Charge ID: [0-9]+\\\\)\\\\. `)\n    return pattern.test(note);\n}\n\n// Select all <p> elements within ul.order_notes > li > div > p\nconst notes = document.querySelectorAll('ul.order_notes > li > div > p');\n\n// Check if any note matches the pattern\nreturn Array.from(notes).some(note => checkAdminNote(note.textContent));\n\n",
      "variableName": ""
    },
    {
      "command": "assertEval",
      "condition": null,
      "optional": false,
      "private": false,
      "sequence": 15,
      "target": "",
      "value": "function checkAdminNote(note) {\n    const email = '{{email}}'.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&')\n    const pattern = new RegExp(` points earned via points For Purchase \\\\(${email}\\\\)`)\n    return pattern.test(note);\n}\n\n// Select all <p> elements within ul.order_notes > li > div > p\nconst notes = document.querySelectorAll('ul.order_notes > li > div > p');\n\n// Check if any note matches the pattern\nreturn Array.from(notes).some(note => checkAdminNote(note.textContent));\n\n",
      "variableName": ""
    },
