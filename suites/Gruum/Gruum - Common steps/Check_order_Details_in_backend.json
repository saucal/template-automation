    {
      "command": "assertText",
      "condition": null,
      "optional": false,
      "private": false,
      "sequence": 11,
      "target": ".wc-order-data-row.wc-order-totals-items > table.wc-order-totals:nth-of-type(1) > tbody > tr:nth-of-type(3) > td.total > .woocommerce-Price-amount.amount > bdi",
      "value": "{{total}}",
      "variableName": ""
