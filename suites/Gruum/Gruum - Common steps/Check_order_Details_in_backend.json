    {
      "command": "assertEval",
      "condition": {
        "statement": "return '{{paymentMethod}}' !== 'PayPal'"
      },
      "optional": false,
      "private": false,
      "sequence": 12,
      "target": "",
      "value": "const total = '{{total}}'\nfunction checkAdminNote(note) {\n    const pattern = new RegExp  (`A payment of ${total} was successfully charged using WooPayments \\\\(pi_[a-zA-Z0-9]+\\\\)`);\n    return pattern.test(note);\n}\n\n// Select all <p> elements within ul.order_notes > li > div > p\nconst notes = document.querySelectorAll('ul.order_notes > li > div > p');\n\n// Check if any note matches the pattern\nreturn Array.from(notes).some(note => checkAdminNote(note.textContent));\n",
      "variableName": ""
    },
    {
      "command": "assertEval",
      "condition": {
        "statement": "return '{{paymentMethod}}' === 'PayPal'"
      },
      "optional": false,
      "private": false,
      "sequence": 13,
      "target": "",
      "value": "const total = '{{total}}'\nfunction checkAdminNote(note) {\n    const pattern = new RegExp  (`Braintree \\\\(PayPal\\\\) Sandbox Payment Approved \\\\(Transaction ID [a-zA-Z0-9]+\\\\)`);\n    return pattern.test(note);\n}\n//Braintree (PayPal) Sandbox Payment Approved (Transaction ID jtk5b7f2)\n// Select all <p> elements within ul.order_notes > li > div > p\nconst notes = document.querySelectorAll('ul.order_notes > li > div > p');\n\n// Check if any note matches the pattern\nreturn Array.from(notes).some(note => checkAdminNote(note.textContent));\n",
      "variableName": ""
    }
