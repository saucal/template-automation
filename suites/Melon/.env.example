# Per-environment base URLs (WITH trailing slash — goto() is always relative, rule 12).
# Each Playwright project maps to one of these (rule 34).
BASE_URL_MAINTENANCE="https://melonoptics-maintenance.mystagingwebsite.com/"
# BASE_URL is the fallback / "staging" environment.
BASE_URL="https://melonoptics-staging.mystagingwebsite.com/"

# WordPress admin credentials — used for lazy per-env admin auth (helpers/admin-login.ts)
WP_ADMIN_USER=admin
ADMIN_PASS=password

# Test credentials (private GI variables)
PAY_PAL_PASS=
PASSWORD=
PASSWORD2=
