{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "playwright.config.ts",
    "specs/**/*.ts",
    "helpers/**/*.ts",
    "fixtures/**/*.ts",
    "types/**/*.ts"
  ],
  "exclude": ["node_modules", "generated"]
}
