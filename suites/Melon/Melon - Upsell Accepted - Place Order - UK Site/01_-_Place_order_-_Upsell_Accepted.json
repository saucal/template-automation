      "target": "",
      "value": "\nlet total = parseFloat(\"{{total}}\".replace(\"{{Symbol}}\",\"\").trim());\nlet price2 = parseFloat(\"{{price2}}\".replace(\"{{Symbol}}\",\"\").trim());\nlet price3 = \"{{price3}}\"\nif (price3 !== \"\") {\n    price3 = parseFloat(price3.replace(\"{{Symbol}}\",\"\").trim());\n} else {\n    price3 = 0\n}\n\n\ntotal = total+price2+price3\n\ntotal = Intl.NumberFormat('en-IN', { style: 'currency', currency: 'GBP'}).format(total)\n\nreturn total\n\n",
      "variableName": "total"
    },
