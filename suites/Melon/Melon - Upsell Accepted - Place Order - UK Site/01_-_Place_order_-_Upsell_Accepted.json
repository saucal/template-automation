    {
      "command": "extractEval",
      "condition": {
        "statement": "return \"{{upsell}}\" === \"yes\" && \"{{accept}}\" === \"yes\""
      },
      "optional": false,
      "private": false,
      "sequence": 11,
      "target": "",
      "value": "\nlet total = parseFloat(\"{{subtotalPrice}}\".replace(\"{{Symbol}}\",\"\").trim());\nlet shipping = parseFloat(\"{{shippingPrice}}\".replace(\"{{Symbol}}\",\"\").trim());\nlet price2 = parseFloat(\"{{price2}}\".replace(\"{{Symbol}}\",\"\").trim());\nlet price3 = \"{{price3}}\"\nif (price3 !== \"\") {\n    price3 = parseFloat(price3.replace(\"{{Symbol}}\",\"\").trim());\n} else {\n    price3 = 0\n}\n\ntotal = total - ( total / 1.2 )\nshipping = shipping - ( shipping / 1.2 )\nprice2 = price2 - ( price2 / 1.2 )\n\nif (price3 !== 0) {\n    price3 = price3 - ( price3 / 1.2 )\n}\n\n\nlet taxPriceSmall = Number(total.toFixed(2))+Number(price2.toFixed(2))+Number(price3.toFixed(2))+Number(shipping.toFixed(2))\n\ntaxPriceSmall = Intl.NumberFormat('en-IN', { style: 'currency', currency: 'GBP'}).format(taxPriceSmall)\n\nreturn taxPriceSmall\n",
      "variableName": "taxPriceSmall"
    },
    {
      "command": "extractEval",
      "condition": {
        "statement": "return \"{{upsell}}\" === \"yes\" && \"{{accept}}\" === \"yes\""
