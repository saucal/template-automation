      "target": "",
      "value": "const price = parseFloat(\"{{unitPrice}}\".replace(\"{{Symbol}}\",\"\").replaceAll(\",\",\"\").trim());\nlet shippingPrice = \"{{shippingPrice}}\"\n\nif (shippingPrice.includes('FREE')) {\n    shippingPrice = '0.00'\n}\n\nshippingPrice = parseFloat(shippingPrice.replace(\"{{Symbol}}\",\"\").replaceAll(\",\",\"\").trim());\nconst tax = parseFloat(\"{{taxPrice}}\".replace(\"{{Symbol}}\",\"\").replaceAll(\",\",\"\").trim());\nconst costPrice = parseFloat(\"{{costPrice}}\".replace(\"{{Symbol}}\",\"\").replaceAll(\",\",\"\").trim());\nconst costTax = parseFloat(\"{{costTax}}\".replace(\"{{Symbol}}\",\"\").replaceAll(\",\",\"\").trim());\nconst costShipping = parseFloat(\"{{costShipping}}\".replace(\"{{Symbol}}\",\"\").replaceAll(\",\",\"\").trim());\nconst costShippingTax = parseFloat(\"{{costShippingTax}}\".replace(\"{{Symbol}}\",\"\").replaceAll(\",\",\"\").trim());\n\nlet price2 = Number((costPrice + costTax).toFixed(2));\nlet shippingPrice2 = Number((costShipping + costShippingTax).toFixed(2));\nlet tax2 = Number((costTax + costShippingTax).toFixed(2));\n\nreturn price === price \n        && shippingPrice === shippingPrice2\n        && tax === tax2",
      "variableName": ""
