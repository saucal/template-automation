      "value": "let unit = \"{{subtotalPrice}}\";\nlet prodDiscount = \"{{prodDiscount}}\"\nlet shipping = \"{{shippingPrice}}\";\nlet shipDiscount = \"{{shipDiscount}}\";\nif (shipping.includes(\"Free\")){\n    shipping = \"0.00\";\n};\nif (prodDiscount === \"\"){\n    prodDiscount = \"0.00\";\n};\nif (shipDiscount === \"\"){\n    shipDiscount = \"0.00\";\n};\nlet tax = \"{{taxPrice}}\";\nlet total = \"{{total}}\";\n\n\nunit = unit.replace(\",\",\"\");\nshipping = shipping.replace(\",\",\"\");\nprodDiscount = prodDiscount.replace(\",\",\"\");\nshipDiscount = shipDiscount.replace(\",\",\"\");\ntax = tax.replace(\",\",\"\");\ntotal = total.replace(\",\",\"\");\n\nunit = Number(unit.replace(\"{{Symbol}}\",\"\"));\nshipping = Number(shipping.replace(\"{{Symbol}}\",\"\"));\nprodDiscount = Number(prodDiscount.replace(\"{{Symbol}}\",\"\"));\nshipDiscount = Number(shipDiscount.replace(\"{{Symbol}}\",\"\"));\ntax = Number(tax.replace(\"{{Symbol}}\",\"\"));\ntotal = Number(total.replace(\"{{Symbol}}\",\"\"));\n\nlet total2 = unit-prodDiscount+shipping-shipDiscount+tax;\ntotal2 = Number(total2.toFixed(2));\n\nreturn total === total2",
