      "optional": false,
      "private": false,
      "sequence": 0,
      "target": "",
      "value": "const unitPrice = parseFloat('{{unitPrice}}'.replace('$','').replace(',','').trim())\nconst upsellPrice = parseFloat('{{upsellPrice}}'.replace('$','').replace(',','').trim())\n\nconst amount = unitPrice + upsellPrice;\nconst usdFormatter = new Intl.NumberFormat('en-US', {\n  style: 'currency',\n  currency: 'USD'\n});\nconst subtotal = usdFormatter.format(amount);\n\nreturn subtotal\n\n",
      "variableName": "subtotal"
    },
    {
      "command": "extractEval",
      "condition": {
        "statement": "return '{{upsellPrice}}' !== ''"
      },
      "optional": false,
      "private": false,
      "sequence": 1,
      "target": "",
      "value": "const subtotal = parseFloat('{{subtotal}}'.replace('$','').replace(',','').trim())\nconst discount = parseFloat('{{discount}}'.replace('$','').replace(',','').trim())\n\nconst amount = (subtotal - discount) * 0.07;\nconst usdFormatter = new Intl.NumberFormat('en-US', {\n  style: 'currency',\n  currency: 'USD'\n});\nconst tax = usdFormatter.format(amount);\n\nreturn tax\n\n",
      "variableName": "taxPrice"
    },
    {
      "command": "extractEval",
      "condition": {
        "statement": "return '{{upsellPrice}}' !== ''"
