      "value": "function checkAdminNote(note) {\n    const email = '{{email}}'.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&')\n    const pattern = new RegExp(`Payment via Credit / Debit Card \\\\(ch_[0-9a-zA-Z]+\\\\)\\\\.`)\n    return pattern.test(note);\n}\n\n// Select all <p> elements within ul.order_notes > li > div > p\nconst notes = document.querySelectorAll('ul.order_notes > li > div > p');\n\n// Check if any note matches the pattern\nreturn Array.from(notes).some(note => checkAdminNote(note.textContent));\n\n",
