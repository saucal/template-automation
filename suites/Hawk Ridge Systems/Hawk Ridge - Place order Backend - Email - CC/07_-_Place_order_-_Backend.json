      "sequence": 15,
      "target": "",
      "value": "// Select all price <bdi> elements\nconst priceElements = document.querySelectorAll(\n  'tr > td.line_cost > .view > .woocommerce-Price-amount.amount > bdi'\n);\n\nlet total = 0;\nconst prices = [];\n\npriceElements.forEach(el => {\n  const text = el.innerText.trim(); // e.g., \"$1,999.99\"\n  \n  // Remove $ and commas, then convert to number\n  const value = parseFloat(text.replace(/[$,]/g, ''));\n  \n  if (!isNaN(value)) {\n    prices.push(value);\n    total += value;\n  }\n});\n\nconsole.log('Individual prices:', prices);\nconsole.log('Total sum:', total);\nconsole.log('Formatted total: $' + total.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }));\n\n\nreturn '{{unitPrice}}' === '$' + total.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })",
      "variableName": ""
    },
