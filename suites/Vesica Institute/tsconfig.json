{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node", "@playwright/test"],
    "noEmit": true,
    "typeRoots": ["node_modules/@types", "node_modules"]
  },
  "include": [
    "*.ts",
    "specs/**/*.ts",
    "helpers/**/*.ts",
    "fixtures/**/*.ts",
    "types/**/*.ts"
  ],
  "exclude": ["node_modules", "generated"]
}
